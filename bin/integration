# ##########################################################################
#
#  SECTION 4: CROSS-CUTTING / FULL DISCOVERY FLOWS
#
# ##########################################################################

echo ""
echo "# --- Discovery flows ---"

# ==========================================================================
# Full discovery: PROPFIND / -> calendar-home-set -> list calendars
# ==========================================================================
test_name="Full discovery: root -> calendar-home-set -> list calendars"
# Create a temporary calendar for this test
curl -s -o /dev/null -X MKCALENDAR -u "$AUTH" -H "Content-Type: text/xml" \
  -d '<c:mkcalendar xmlns:d="DAV:" xmlns:c="urn:ietf:params:xml:ns:caldav"><d:set><d:prop><d:displayname>Discovery Cal</d:displayname></d:prop></d:set></c:mkcalendar>' \
  "${BASE_URL}/calendars/admin/inttest/" 2>/dev/null

result=$(dav_full PROPFIND / -H "Depth: 0" -H "Content-Type: text/xml" \
  -d '<?xml version="1.0" encoding="UTF-8"?><d:propfind xmlns:d="DAV:"><d:prop><d:current-user-principal/></d:prop></d:propfind>')
actual_status=$(echo "$result" | head -1)
actual_body=$(echo "$result" | tail -n +2)
norm_actual=$(echo "$actual_body" | normalize)
# Verify discovery chain
if [ "$actual_status" = "207" ] && echo "$norm_actual" | grep -q '/admin/' && echo "$norm_actual" | grep -q '/calendars/admin/'; then
  # Now list calendars at home set
  result2=$(dav_full PROPFIND /calendars/admin/ -H "Depth: 1" -H "Content-Type: text/xml")
  actual_status2=$(echo "$result2" | head -1)
  actual_body2=$(echo "$result2" | tail -n +2)
  norm_actual2=$(echo "$actual_body2" | normalize)
  if [ "$actual_status2" = "207" ] && echo "$norm_actual2" | grep -q 'Discovery Cal'; then
    PASS=$((PASS + 1))
    echo "ok - ${test_name}"
  else
    FAIL=$((FAIL + 1))
    ERRORS="${ERRORS}\nFAIL ${test_name}: calendar not found at home set"
    echo "not ok - ${test_name}"
  fi
else
  FAIL=$((FAIL + 1))
  ERRORS="${ERRORS}\nFAIL ${test_name}: discovery root failed"
  echo "not ok - ${test_name}"
fi

curl -s -X DELETE -u "$AUTH" "${BASE_URL}/calendars/admin/inttest/" >/dev/null 2>&1 || true

# ==========================================================================
# Full discovery: PROPFIND / -> addressbook-home-set -> list addressbooks
# ==========================================================================
test_name="Full discovery: root -> addressbook-home-set -> list addressbooks"
curl -s -o /dev/null -X MKCOL -u "$AUTH" -H "Content-Type: text/xml" \
  -d '<d:mkcol xmlns:d="DAV:" xmlns:cr="urn:ietf:params:xml:ns:carddav"><d:set><d:prop><d:resourcetype><d:collection/><cr:addressbook/></d:resourcetype><d:displayname>Discovery Addr</d:displayname></d:prop></d:set></d:mkcol>' \
  "${BASE_URL}/addressbooks/admin/inttest/" 2>/dev/null

result=$(dav_full PROPFIND / -H "Depth: 0" -H "Content-Type: text/xml" \
  -d '<?xml version="1.0" encoding="UTF-8"?><d:propfind xmlns:d="DAV:"><d:prop><d:current-user-principal/></d:prop></d:propfind>')
actual_status=$(echo "$result" | head -1)
actual_body=$(echo "$result" | tail -n +2)
norm_actual=$(echo "$actual_body" | normalize)
if [ "$actual_status" = "207" ] && echo "$norm_actual" | grep -q '/addressbooks/admin/'; then
  result2=$(dav_full PROPFIND /addressbooks/admin/ -H "Depth: 1" -H "Content-Type: text/xml")
  actual_status2=$(echo "$result2" | head -1)
  actual_body2=$(echo "$result2" | tail -n +2)
  norm_actual2=$(echo "$actual_body2" | normalize)
  if [ "$actual_status2" = "207" ] && echo "$norm_actual2" | grep -q 'Discovery Addr'; then
    PASS=$((PASS + 1))
    echo "ok - ${test_name}"
  else
    FAIL=$((FAIL + 1))
    ERRORS="${ERRORS}\nFAIL ${test_name}: addressbook not found at home set"
    echo "not ok - ${test_name}"
  fi
else
  FAIL=$((FAIL + 1))
  ERRORS="${ERRORS}\nFAIL ${test_name}: discovery root failed"
  echo "not ok - ${test_name}"
fi

curl -s -X DELETE -u "$AUTH" "${BASE_URL}/addressbooks/admin/inttest/" >/dev/null 2>&1 || true

# ==========================================================================
# Cleanup
# ==========================================================================
curl -s -X DELETE -u "$AUTH" "${BASE_URL}/calendars/admin/inttest/" >/dev/null 2>&1 || true
curl -s -X DELETE -u "$AUTH" "${BASE_URL}/calendars/admin/inttest2/" >/dev/null 2>&1 || true
curl -s -X DELETE -u "$AUTH" "${BASE_URL}/addressbooks/admin/inttest/" >/dev/null 2>&1 || true
curl -s -X DELETE -u "$AUTH" "${BASE_URL}/addressbooks/admin/inttest2/" >/dev/null 2>&1 || true

# ==========================================================================
# Summary
# ==========================================================================
echo ""
TOTAL=$((PASS + FAIL))
if [ "$FAIL" -gt 0 ]; then
  echo -e "\033[31m# ${TOTAL} integration tests: ${PASS} passed, ${FAIL} failed\033[0m"
  echo -e "$ERRORS"
  exit 1
else
  echo -e "\033[32m# ${TOTAL} integration tests: ${PASS} passed, 0 failed\033[0m"
  exit 0
fi
