#!/usr/bin/env bash
set -euo pipefail

# Integration tests -- hits the real server with curl, validates full XML responses.
# Expects the server running at BASE_URL (default http://localhost:9292)
# with basic auth admin:admin.

BASE_URL="${BASE_URL:-http://localhost:9292}"
AUTH="admin:admin"
PASS=0
FAIL=0
ERRORS=""

normalize() {
  # Collapse all runs of whitespace (including newlines) between > and < into nothing
  tr '\n' ' ' | sed 's/>[[:space:]]*</></g; s/^[[:space:]]*//; s/[[:space:]]*$//'
}

assert_response() {
  local test_name="$1"
  local expected_status="$2"
  local expected_body="$3"
  local actual_status="$4"
  local actual_body="$5"

  local norm_expected norm_actual

  if [ "$actual_status" != "$expected_status" ]; then
    FAIL=$((FAIL + 1))
    ERRORS="${ERRORS}\nFAIL ${test_name}: expected status ${expected_status}, got ${actual_status}"
    echo "not ok - ${test_name} (status ${actual_status} != ${expected_status})"
    return
  fi

  if [ -n "$expected_body" ]; then
    norm_expected=$(echo "$expected_body" | normalize)
    norm_actual=$(echo "$actual_body" | normalize)

    if [ "$norm_actual" != "$norm_expected" ]; then
      FAIL=$((FAIL + 1))
      ERRORS="${ERRORS}\nFAIL ${test_name}:"
      ERRORS="${ERRORS}\n  EXPECTED: ${norm_expected}"
      ERRORS="${ERRORS}\n  ACTUAL:   ${norm_actual}"
      # Show a diff for easier debugging
      local diff_out
      diff_out=$(diff <(echo "$norm_expected") <(echo "$norm_actual") || true)
      ERRORS="${ERRORS}\n  DIFF:\n${diff_out}"
      echo "not ok - ${test_name}"
      return
    fi
  fi

  PASS=$((PASS + 1))
  echo "ok - ${test_name}"
}

assert_contains() {
  local test_name="$1"
  local expected_status="$2"
  local actual_status="$3"
  local actual_body="$4"
  shift 4
  # Remaining args are strings that must appear in the body

  if [ "$actual_status" != "$expected_status" ]; then
    FAIL=$((FAIL + 1))
    ERRORS="${ERRORS}\nFAIL ${test_name}: expected status ${expected_status}, got ${actual_status}"
    echo "not ok - ${test_name} (status ${actual_status} != ${expected_status})"
    return
  fi

  local norm_actual
  norm_actual=$(echo "$actual_body" | normalize)
  for needle in "$@"; do
    if ! echo "$norm_actual" | grep -q "$needle"; then
      FAIL=$((FAIL + 1))
      ERRORS="${ERRORS}\nFAIL ${test_name}: body missing '${needle}'"
      echo "not ok - ${test_name} (missing '${needle}')"
      return
    fi
  done

  PASS=$((PASS + 1))
  echo "ok - ${test_name}"
}

assert_not_contains() {
  local test_name="$1"
  local expected_status="$2"
  local actual_status="$3"
  local actual_body="$4"
  shift 4

  if [ "$actual_status" != "$expected_status" ]; then
    FAIL=$((FAIL + 1))
    ERRORS="${ERRORS}\nFAIL ${test_name}: expected status ${expected_status}, got ${actual_status}"
    echo "not ok - ${test_name} (status ${actual_status} != ${expected_status})"
    return
  fi

  local norm_actual
  norm_actual=$(echo "$actual_body" | normalize)
  for needle in "$@"; do
    if echo "$norm_actual" | grep -q "$needle"; then
      FAIL=$((FAIL + 1))
      ERRORS="${ERRORS}\nFAIL ${test_name}: body should NOT contain '${needle}'"
      echo "not ok - ${test_name} (unexpected '${needle}')"
      return
    fi
  done

  PASS=$((PASS + 1))
  echo "ok - ${test_name}"
}

dav() {
  # dav METHOD PATH [extra curl args...]
  # Returns just the status code.
  local method="$1"
  local path="$2"
  shift 2
  curl -s -o /dev/null -w '%{http_code}' -X "$method" -u "$AUTH" "$@" "${BASE_URL}${path}" 2>/dev/null || true
}

dav_no_auth() {
  local method="$1"
  local path="$2"
  shift 2
  curl -s -o /dev/null -w '%{http_code}' -X "$method" "$@" "${BASE_URL}${path}" 2>/dev/null || true
}

dav_full() {
  # Returns status as first line, body as remaining lines
  local method="$1"
  local path="$2"
  shift 2
  local tmpfile
  tmpfile=$(mktemp)
  local status
  status=$(curl -s -o "$tmpfile" -w '%{http_code}' -X "$method" -u "$AUTH" "$@" "${BASE_URL}${path}" 2>/dev/null || true)
  echo "$status"
  cat "$tmpfile"
  rm -f "$tmpfile"
}

dav_headers() {
  # Returns full response headers
  local method="$1"
  local path="$2"
  shift 2
  curl -s -D- -o /dev/null -X "$method" -u "$AUTH" "$@" "${BASE_URL}${path}" 2>/dev/null || true
}

strip_ctag() {
  sed 's/<cs:getctag>[^<]*<\/cs:getctag>/<cs:getctag>CTAG<\/cs:getctag>/g'
}

strip_etag() {
  sed 's/<d:getetag>[^<]*<\/d:getetag>/<d:getetag>ETAG<\/d:getetag>/g'
}

echo "# Integration tests against ${BASE_URL}"
echo ""

# --------------------------------------------------------------------------
# Clean slate -- delete any leftover test collections
# --------------------------------------------------------------------------
curl -s -X DELETE -u "$AUTH" "${BASE_URL}/calendars/admin/inttest/" >/dev/null 2>&1 || true
curl -s -X DELETE -u "$AUTH" "${BASE_URL}/calendars/admin/inttest2/" >/dev/null 2>&1 || true
curl -s -X DELETE -u "$AUTH" "${BASE_URL}/addressbooks/admin/inttest/" >/dev/null 2>&1 || true
curl -s -X DELETE -u "$AUTH" "${BASE_URL}/addressbooks/admin/inttest2/" >/dev/null 2>&1 || true

# ##########################################################################
#
#  SECTION 1: DISCOVERY & ROOT ENDPOINTS
#
# ##########################################################################

echo "# --- Discovery & Root ---"

# ==========================================================================
# OPTIONS / returns DAV headers
# ==========================================================================
test_name="OPTIONS / returns DAV headers with calendar-access"
headers=$(dav_headers OPTIONS /)
if echo "$headers" | grep -qi 'dav:.*calendar-access'; then
  PASS=$((PASS + 1))
  echo "ok - ${test_name}"
else
  FAIL=$((FAIL + 1))
  ERRORS="${ERRORS}\nFAIL ${test_name}: missing DAV header with calendar-access"
  echo "not ok - ${test_name}"
fi

# ==========================================================================
# OPTIONS / includes addressbook in DAV header
# ==========================================================================
test_name="OPTIONS / returns DAV headers with addressbook"
if echo "$headers" | grep -qi 'dav:.*addressbook'; then
  PASS=$((PASS + 1))
  echo "ok - ${test_name}"
else
  FAIL=$((FAIL + 1))
  ERRORS="${ERRORS}\nFAIL ${test_name}: missing DAV header with addressbook"
  echo "not ok - ${test_name}"
fi

# ==========================================================================
# PROPFIND / returns discovery XML
# ==========================================================================
test_name="PROPFIND / returns current-user-principal discovery"
result=$(dav_full PROPFIND / -H "Depth: 0" -H "Content-Type: text/xml" \
  -d '<?xml version="1.0" encoding="UTF-8"?><d:propfind xmlns:d="DAV:"><d:prop><d:current-user-principal/></d:prop></d:propfind>')
actual_status=$(echo "$result" | head -1)
actual_body=$(echo "$result" | tail -n +2)

expected_body=$(cat <<'XML'
<?xml version="1.0" encoding="UTF-8"?>
<d:multistatus xmlns:d="DAV:" xmlns:c="urn:ietf:params:xml:ns:caldav" xmlns:cr="urn:ietf:params:xml:ns:carddav" xmlns:cs="http://calendarserver.org/ns/" xmlns:x="http://apple.com/ns/ical/">
  <d:response>
    <d:href>/</d:href>
    <d:propstat>
      <d:prop>
        <d:resourcetype><d:collection/></d:resourcetype>
        <d:current-user-principal><d:href>/admin/</d:href></d:current-user-principal>
        <c:calendar-home-set><d:href>/calendars/admin/</d:href></c:calendar-home-set>
        <cr:addressbook-home-set><d:href>/addressbooks/admin/</d:href></cr:addressbook-home-set>
      </d:prop>
      <d:status>HTTP/1.1 200 OK</d:status>
    </d:propstat>
  </d:response>
</d:multistatus>
XML
)
assert_response "$test_name" "207" "$expected_body" "$actual_status" "$actual_body"

# ==========================================================================
# PROPFIND / without auth returns 401
# ==========================================================================
test_name="PROPFIND / without auth returns 401"
actual_status=$(dav_no_auth PROPFIND / -H "Depth: 0")
assert_response "$test_name" "401" "" "$actual_status" ""

# ==========================================================================
# GET / returns 200
# ==========================================================================
test_name="GET / returns 200"
actual_status=$(dav GET /)
assert_response "$test_name" "200" "" "$actual_status" ""

# ==========================================================================
# .well-known/caldav returns useful response
# ==========================================================================
test_name=".well-known/caldav PROPFIND returns discovery"
result=$(dav_full PROPFIND /.well-known/caldav -H "Depth: 0")
actual_status=$(echo "$result" | head -1)
actual_body=$(echo "$result" | tail -n +2)
assert_contains "$test_name" "207" "$actual_status" "$actual_body" "current-user-principal" "calendar-home-set"

# ==========================================================================
# .well-known/carddav returns useful response
# ==========================================================================
test_name=".well-known/carddav PROPFIND returns discovery"
result=$(dav_full PROPFIND /.well-known/carddav -H "Depth: 0")
actual_status=$(echo "$result" | head -1)
actual_body=$(echo "$result" | tail -n +2)
assert_contains "$test_name" "207" "$actual_status" "$actual_body" "current-user-principal" "addressbook-home-set"

# ==========================================================================
# .well-known/caldav GET returns 200
# ==========================================================================
test_name=".well-known/caldav GET returns 200"
actual_status=$(dav GET /.well-known/caldav)
assert_response "$test_name" "200" "" "$actual_status" ""

# ==========================================================================
# .well-known/carddav GET returns 200
# ==========================================================================
test_name=".well-known/carddav GET returns 200"
actual_status=$(dav GET /.well-known/carddav)
assert_response "$test_name" "200" "" "$actual_status" ""

# ##########################################################################
#
#  SECTION 2: CALENDAR (CalDAV)
#
# ##########################################################################

echo ""
echo "# --- Calendar: MKCALENDAR ---"

# ==========================================================================
# MKCALENDAR creates a calendar
# ==========================================================================
test_name="MKCALENDAR creates calendar and returns 201"
mkcal_body='<c:mkcalendar xmlns:d="DAV:" xmlns:c="urn:ietf:params:xml:ns:caldav"><d:set><d:prop><d:displayname>IntTest Cal</d:displayname><c:calendar-description>Test description</c:calendar-description></d:prop></d:set></c:mkcalendar>'
actual_status=$(curl -s -o /dev/null -w '%{http_code}' -X MKCALENDAR -u "$AUTH" -H "Content-Type: text/xml" -d "$mkcal_body" "${BASE_URL}/calendars/admin/inttest/" 2>/dev/null)
assert_response "$test_name" "201" "" "$actual_status" ""

# ==========================================================================
# MKCALENDAR 405 when calendar already exists
# ==========================================================================
test_name="MKCALENDAR returns 405 when calendar already exists"
actual_status=$(curl -s -o /dev/null -w '%{http_code}' -X MKCALENDAR -u "$AUTH" -H "Content-Type: text/xml" -d "$mkcal_body" "${BASE_URL}/calendars/admin/inttest/" 2>/dev/null)
assert_response "$test_name" "405" "" "$actual_status" ""

# ==========================================================================
# MKCALENDAR 409 when parent does not exist
# ==========================================================================
test_name="MKCALENDAR returns 409 when parent does not exist"
actual_status=$(curl -s -o /dev/null -w '%{http_code}' -X MKCALENDAR -u "$AUTH" -H "Content-Type: text/xml" -d "$mkcal_body" "${BASE_URL}/calendars/admin/nope/deep/" 2>/dev/null)
assert_response "$test_name" "409" "" "$actual_status" ""

# ==========================================================================
# MKCALENDAR with empty body
# ==========================================================================
test_name="MKCALENDAR with empty body returns 201"
actual_status=$(curl -s -o /dev/null -w '%{http_code}' -X MKCALENDAR -u "$AUTH" "${BASE_URL}/calendars/admin/inttest2/" 2>/dev/null)
assert_response "$test_name" "201" "" "$actual_status" ""
# cleanup
curl -s -X DELETE -u "$AUTH" "${BASE_URL}/calendars/admin/inttest2/" >/dev/null 2>&1 || true

# ==========================================================================
# MKCALENDAR without auth returns 401
# ==========================================================================
test_name="MKCALENDAR without auth returns 401"
actual_status=$(dav_no_auth MKCALENDAR /calendars/admin/inttest-noauth/)
assert_response "$test_name" "401" "" "$actual_status" ""

echo "# --- Calendar: OPTIONS ---"

# ==========================================================================
# OPTIONS on calendar path
# ==========================================================================
test_name="OPTIONS /calendars/ returns DAV headers"
headers=$(dav_headers OPTIONS /calendars/admin/inttest/)
status=$(echo "$headers" | head -1 | grep -o '[0-9][0-9][0-9]')
if [ "$status" = "200" ] && echo "$headers" | grep -qi 'dav:'; then
  PASS=$((PASS + 1))
  echo "ok - ${test_name}"
else
  FAIL=$((FAIL + 1))
  ERRORS="${ERRORS}\nFAIL ${test_name}: expected 200 with DAV header"
  echo "not ok - ${test_name}"
fi

echo "# --- Calendar: PROPFIND ---"

# ==========================================================================
# PROPFIND calendar depth 0
# ==========================================================================
test_name="PROPFIND calendar collection depth 0 returns full response"
result=$(dav_full PROPFIND /calendars/admin/inttest/ -H "Depth: 0" -H "Content-Type: text/xml")
actual_status=$(echo "$result" | head -1)
actual_body=$(echo "$result" | tail -n +2)
actual_body_stripped=$(echo "$actual_body" | strip_ctag)

expected_body=$(cat <<'XML' | strip_ctag
<?xml version="1.0" encoding="UTF-8"?>
<d:multistatus xmlns:d="DAV:" xmlns:c="urn:ietf:params:xml:ns:caldav" xmlns:cr="urn:ietf:params:xml:ns:carddav" xmlns:cs="http://calendarserver.org/ns/" xmlns:x="http://apple.com/ns/ical/">
  <d:response>
    <d:href>/calendars/admin/inttest/</d:href>
    <d:propstat>
      <d:prop>
        <d:resourcetype><d:collection/><c:calendar/></d:resourcetype>
        <d:displayname>IntTest Cal</d:displayname>
        <c:calendar-description>Test description</c:calendar-description>
        <cs:getctag>CTAG</cs:getctag>
        <c:supported-calendar-component-set><c:comp name="VEVENT"/><c:comp name="VTODO"/><c:comp name="VJOURNAL"/></c:supported-calendar-component-set>
      </d:prop>
      <d:status>HTTP/1.1 200 OK</d:status>
    </d:propstat>
  </d:response>
</d:multistatus>
XML
)
assert_response "$test_name" "207" "$expected_body" "$actual_status" "$actual_body_stripped"

# ==========================================================================
# PROPFIND without auth returns 401
# ==========================================================================
test_name="PROPFIND calendar without auth returns 401"
actual_status=$(dav_no_auth PROPFIND /calendars/admin/inttest/ -H "Depth: 0")
assert_response "$test_name" "401" "" "$actual_status" ""

# ==========================================================================
# PROPFIND on non-existent calendar returns 404
# ==========================================================================
test_name="PROPFIND non-existent calendar returns 404"
actual_status=$(dav PROPFIND /calendars/admin/doesnotexist/nope/ -H "Depth: 0")
assert_response "$test_name" "404" "" "$actual_status" ""

# ==========================================================================
# PROPFIND depth 1 lists children
# ==========================================================================
test_name="PROPFIND calendar depth 1 includes child items"
# Put an event first
event_body="BEGIN:VCALENDAR
VERSION:2.0
BEGIN:VEVENT
UID:propfind-depth1-test
SUMMARY:Depth1 Event
DTSTART:20260501T100000Z
END:VEVENT
END:VCALENDAR"
curl -s -o /dev/null -X PUT -u "$AUTH" \
  -H "Content-Type: text/calendar" \
  --data-binary "$event_body" \
  "${BASE_URL}/calendars/admin/inttest/depth1.ics" 2>/dev/null
result=$(dav_full PROPFIND /calendars/admin/inttest/ -H "Depth: 1" -H "Content-Type: text/xml")
actual_status=$(echo "$result" | head -1)
actual_body=$(echo "$result" | tail -n +2)
assert_contains "$test_name" "207" "$actual_status" "$actual_body" "depth1.ics" "/calendars/admin/inttest/"
curl -s -X DELETE -u "$AUTH" "${BASE_URL}/calendars/admin/inttest/depth1.ics" >/dev/null 2>&1 || true

echo "# --- Calendar: PUT ---"

# ==========================================================================
# PUT event returns 201
# ==========================================================================
test_name="PUT event returns 201"
event_body="BEGIN:VCALENDAR
VERSION:2.0
BEGIN:VEVENT
UID:integration-test-1
SUMMARY:Test Event
DTSTART:20260501T100000Z
DTEND:20260501T110000Z
END:VEVENT
END:VCALENDAR"
actual_status=$(curl -s -o /dev/null -w '%{http_code}' -X PUT -u "$AUTH" \
  -H "Content-Type: text/calendar" \
  --data-binary "$event_body" \
  "${BASE_URL}/calendars/admin/inttest/ev1.ics" 2>/dev/null)
assert_response "$test_name" "201" "" "$actual_status" ""

# ==========================================================================
# PUT returns ETag header on create
# ==========================================================================
test_name="PUT event returns ETag header on create"
etag_ev="BEGIN:VCALENDAR
VERSION:2.0
BEGIN:VEVENT
UID:etag-header-test
SUMMARY:ETag Header
DTSTART:20260501T100000Z
END:VEVENT
END:VCALENDAR"
headers=$(curl -s -D- -o /dev/null -X PUT -u "$AUTH" \
  -H "Content-Type: text/calendar" \
  --data-binary "$etag_ev" \
  "${BASE_URL}/calendars/admin/inttest/etag-hdr.ics" 2>/dev/null)
if echo "$headers" | grep -qi '^etag:'; then
  PASS=$((PASS + 1))
  echo "ok - ${test_name}"
else
  FAIL=$((FAIL + 1))
  ERRORS="${ERRORS}\nFAIL ${test_name}: missing ETag header"
  echo "not ok - ${test_name}"
fi
curl -s -X DELETE -u "$AUTH" "${BASE_URL}/calendars/admin/inttest/etag-hdr.ics" >/dev/null 2>&1 || true

# ==========================================================================
# PUT with empty body returns 400
# ==========================================================================
test_name="PUT event with empty body returns 400"
actual_status=$(curl -s -o /dev/null -w '%{http_code}' -X PUT -u "$AUTH" \
  -H "Content-Type: text/calendar" \
  --data-binary "" \
  "${BASE_URL}/calendars/admin/inttest/empty.ics" 2>/dev/null)
assert_response "$test_name" "400" "" "$actual_status" ""

# ==========================================================================
# PUT with invalid body returns 400
# ==========================================================================
test_name="PUT with invalid calendar body returns 400"
actual_status=$(curl -s -o /dev/null -w '%{http_code}' -X PUT -u "$AUTH" \
  -H "Content-Type: text/calendar" \
  --data-binary "NOT A CALENDAR" \
  "${BASE_URL}/calendars/admin/inttest/bad.ics" 2>/dev/null)
assert_response "$test_name" "400" "" "$actual_status" ""

# ==========================================================================
# PUT without auth returns 401
# ==========================================================================
test_name="PUT event without auth returns 401"
actual_status=$(dav_no_auth PUT /calendars/admin/inttest/noauth.ics \
  -H "Content-Type: text/calendar" --data-binary "$event_body")
assert_response "$test_name" "401" "" "$actual_status" ""

# ==========================================================================
# PUT with duplicate UID in same collection returns 409
# ==========================================================================
test_name="PUT with duplicate UID in same collection returns 409"
dup_ev="BEGIN:VCALENDAR
VERSION:2.0
BEGIN:VEVENT
UID:integration-test-1
SUMMARY:Duplicate
DTSTART:20260601T100000Z
END:VEVENT
END:VCALENDAR"
actual_status=$(curl -s -o /dev/null -w '%{http_code}' -X PUT -u "$AUTH" \
  -H "Content-Type: text/calendar" \
  --data-binary "$dup_ev" \
  "${BASE_URL}/calendars/admin/inttest/ev-dup.ics" 2>/dev/null)
assert_response "$test_name" "409" "" "$actual_status" ""

# ==========================================================================
# PUT update to same path with same UID returns 204
# ==========================================================================
test_name="PUT update to same path returns 204"
update_ev="BEGIN:VCALENDAR
VERSION:2.0
BEGIN:VEVENT
UID:integration-test-1
SUMMARY:Updated Event
DTSTART:20260501T100000Z
DTEND:20260501T120000Z
END:VEVENT
END:VCALENDAR"
actual_status=$(curl -s -o /dev/null -w '%{http_code}' -X PUT -u "$AUTH" \
  -H "Content-Type: text/calendar" \
  --data-binary "$update_ev" \
  "${BASE_URL}/calendars/admin/inttest/ev1.ics" 2>/dev/null)
assert_response "$test_name" "204" "" "$actual_status" ""

echo "# --- Calendar: ETag round-trip ---"

# ==========================================================================
# ETag round-trip: PUT, If-Match correct, If-Match wrong, If-None-Match *
# ==========================================================================
test_name="PUT with correct If-Match ETag updates event"
ev_etag_body="BEGIN:VCALENDAR
VERSION:2.0
BEGIN:VEVENT
UID:etag-round-trip
SUMMARY:ETag Test V1
DTSTART:20260601T100000Z
END:VEVENT
END:VCALENDAR"
put_etag=$(curl -s -D- -o /dev/null -X PUT -u "$AUTH" \
  -H "Content-Type: text/calendar" \
  --data-binary "$ev_etag_body" \
  "${BASE_URL}/calendars/admin/inttest/etag-test.ics" 2>/dev/null | grep -i '^etag:' | tr -d '\r' | awk '{print $2}')

ev_etag_body2="BEGIN:VCALENDAR
VERSION:2.0
BEGIN:VEVENT
UID:etag-round-trip
SUMMARY:ETag Test V2
DTSTART:20260601T100000Z
END:VEVENT
END:VCALENDAR"
actual_status=$(curl -s -o /dev/null -w '%{http_code}' -X PUT -u "$AUTH" \
  -H "Content-Type: text/calendar" \
  -H "If-Match: ${put_etag}" \
  --data-binary "$ev_etag_body2" \
  "${BASE_URL}/calendars/admin/inttest/etag-test.ics" 2>/dev/null)
assert_response "$test_name" "204" "" "$actual_status" ""

test_name="PUT with wrong If-Match ETag returns 412"
actual_status=$(curl -s -o /dev/null -w '%{http_code}' -X PUT -u "$AUTH" \
  -H "Content-Type: text/calendar" \
  -H 'If-Match: "totally-wrong"' \
  --data-binary "$ev_etag_body2" \
  "${BASE_URL}/calendars/admin/inttest/etag-test.ics" 2>/dev/null)
assert_response "$test_name" "412" "" "$actual_status" ""

test_name="PUT with If-None-Match * on existing returns 412"
actual_status=$(curl -s -o /dev/null -w '%{http_code}' -X PUT -u "$AUTH" \
  -H "Content-Type: text/calendar" \
  -H 'If-None-Match: *' \
  --data-binary "$ev_etag_body2" \
  "${BASE_URL}/calendars/admin/inttest/etag-test.ics" 2>/dev/null)
assert_response "$test_name" "412" "" "$actual_status" ""

test_name="PUT with If-None-Match * on new item returns 201"
new_ev="BEGIN:VCALENDAR
VERSION:2.0
BEGIN:VEVENT
UID:if-none-new
SUMMARY:New Only
DTSTART:20260601T100000Z
END:VEVENT
END:VCALENDAR"
actual_status=$(curl -s -o /dev/null -w '%{http_code}' -X PUT -u "$AUTH" \
  -H "Content-Type: text/calendar" \
  -H 'If-None-Match: *' \
  --data-binary "$new_ev" \
  "${BASE_URL}/calendars/admin/inttest/if-none-new.ics" 2>/dev/null)
assert_response "$test_name" "201" "" "$actual_status" ""
curl -s -X DELETE -u "$AUTH" "${BASE_URL}/calendars/admin/inttest/if-none-new.ics" >/dev/null 2>&1 || true

echo "# --- Calendar: GET ---"

# ==========================================================================
# GET event returns body
# ==========================================================================
test_name="GET event returns body with correct content-type"
result=$(dav_full GET /calendars/admin/inttest/ev1.ics)
actual_status=$(echo "$result" | head -1)
actual_body=$(echo "$result" | tail -n +2)
assert_contains "$test_name" "200" "$actual_status" "$actual_body" "VCALENDAR" "Updated Event"

# ==========================================================================
# GET missing event returns 404
# ==========================================================================
test_name="GET missing event returns 404"
actual_status=$(dav GET /calendars/admin/inttest/nonexistent.ics)
assert_response "$test_name" "404" "" "$actual_status" ""

# ==========================================================================
# GET collection returns concatenated items
# ==========================================================================
test_name="GET calendar collection returns concatenated items"
result=$(dav_full GET /calendars/admin/inttest/)
actual_status=$(echo "$result" | head -1)
actual_body=$(echo "$result" | tail -n +2)
assert_contains "$test_name" "200" "$actual_status" "$actual_body" "VCALENDAR"

echo "# --- Calendar: HEAD ---"

# ==========================================================================
# HEAD on event returns 200
# ==========================================================================
test_name="HEAD on event returns 200"
head_headers=$(dav_headers HEAD /calendars/admin/inttest/ev1.ics)
head_status=$(echo "$head_headers" | head -1 | grep -o '[0-9][0-9][0-9]')
if [ "$head_status" = "200" ]; then
  PASS=$((PASS + 1))
  echo "ok - ${test_name}"
else
  FAIL=$((FAIL + 1))
  ERRORS="${ERRORS}\nFAIL ${test_name}: expected 200, got ${head_status}"
  echo "not ok - ${test_name}"
fi

# ==========================================================================
# HEAD on event includes ETag header
# ==========================================================================
