  -H "Content-Type: text/vcard" \
  --data-binary "" \
  "${BASE_URL}/addressbooks/admin/inttest/empty.vcf" 2>/dev/null)
assert_response "$test_name" "400" "" "$actual_status" ""

# ==========================================================================
# PUT with invalid vcard body returns 400
# ==========================================================================
test_name="PUT with invalid vcard body returns 400"
actual_status=$(curl -s -o /dev/null -w '%{http_code}' -X PUT -u "$AUTH" \
  -H "Content-Type: text/vcard" \
  --data-binary "NOT A VCARD" \
  "${BASE_URL}/addressbooks/admin/inttest/bad.vcf" 2>/dev/null)
assert_response "$test_name" "400" "" "$actual_status" ""

# ==========================================================================
# PUT contact without auth returns 401
# ==========================================================================
test_name="PUT contact without auth returns 401"
actual_status=$(dav_no_auth PUT /addressbooks/admin/inttest/noauth.vcf \
  -H "Content-Type: text/vcard" --data-binary "$vcard")
assert_response "$test_name" "401" "" "$actual_status" ""

# ==========================================================================
# PUT with duplicate UID in same addressbook returns 409
# ==========================================================================
test_name="PUT contact with duplicate UID returns 409"
dup_vcard="BEGIN:VCARD
VERSION:3.0
UID:int-contact-1
