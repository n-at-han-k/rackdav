  --data-binary "$dup_vcard" \
  "${BASE_URL}/addressbooks/admin/inttest/alice-dup.vcf" 2>/dev/null)
assert_response "$test_name" "409" "" "$actual_status" ""

# ==========================================================================
# PUT update to same path returns 204
# ==========================================================================
test_name="PUT contact update to same path returns 204"
update_vcard="BEGIN:VCARD
VERSION:3.0
UID:int-contact-1
FN:Alice Updated
END:VCARD"
actual_status=$(curl -s -o /dev/null -w '%{http_code}' -X PUT -u "$AUTH" \
  -H "Content-Type: text/vcard" \
  --data-binary "$update_vcard" \
  "${BASE_URL}/addressbooks/admin/inttest/alice.vcf" 2>/dev/null)
assert_response "$test_name" "204" "" "$actual_status" ""

echo "# --- Contacts: ETag round-trip ---"

# ==========================================================================
# Contact ETag: correct If-Match, wrong If-Match, If-None-Match *
# ==========================================================================
test_name="PUT contact with correct If-Match updates"
vcard_etag1="BEGIN:VCARD
VERSION:3.0
UID:etag-contact-rt
FN:ETag V1
END:VCARD"
put_etag=$(curl -s -D- -o /dev/null -X PUT -u "$AUTH" \
  -H "Content-Type: text/vcard" \
  --data-binary "$vcard_etag1" \
  "${BASE_URL}/addressbooks/admin/inttest/etag-rt.vcf" 2>/dev/null | grep -i '^etag:' | tr -d '\r' | awk '{print $2}')

vcard_etag2="BEGIN:VCARD
VERSION:3.0
UID:etag-contact-rt
FN:ETag V2
END:VCARD"
actual_status=$(curl -s -o /dev/null -w '%{http_code}' -X PUT -u "$AUTH" \
  -H "Content-Type: text/vcard" \
  -H "If-Match: ${put_etag}" \
  --data-binary "$vcard_etag2" \
  "${BASE_URL}/addressbooks/admin/inttest/etag-rt.vcf" 2>/dev/null)
assert_response "$test_name" "204" "" "$actual_status" ""

test_name="PUT contact with wrong If-Match returns 412"
actual_status=$(curl -s -o /dev/null -w '%{http_code}' -X PUT -u "$AUTH" \
  -H "Content-Type: text/vcard" \
  -H 'If-Match: "wrong-etag"' \
  --data-binary "$vcard_etag2" \
  "${BASE_URL}/addressbooks/admin/inttest/etag-rt.vcf" 2>/dev/null)
assert_response "$test_name" "412" "" "$actual_status" ""

test_name="PUT contact with If-None-Match * on existing returns 412"
actual_status=$(curl -s -o /dev/null -w '%{http_code}' -X PUT -u "$AUTH" \
  -H "Content-Type: text/vcard" \
  -H 'If-None-Match: *' \
  --data-binary "$vcard_etag2" \
  "${BASE_URL}/addressbooks/admin/inttest/etag-rt.vcf" 2>/dev/null)
assert_response "$test_name" "412" "" "$actual_status" ""

test_name="PUT contact with If-None-Match * on new returns 201"
vcard_new="BEGIN:VCARD
VERSION:3.0
UID:etag-contact-new
FN:Brand New
END:VCARD"
actual_status=$(curl -s -o /dev/null -w '%{http_code}' -X PUT -u "$AUTH" \
  -H "Content-Type: text/vcard" \
  -H 'If-None-Match: *' \
  --data-binary "$vcard_new" \
  "${BASE_URL}/addressbooks/admin/inttest/etag-new.vcf" 2>/dev/null)
assert_response "$test_name" "201" "" "$actual_status" ""
curl -s -X DELETE -u "$AUTH" "${BASE_URL}/addressbooks/admin/inttest/etag-new.vcf" >/dev/null 2>&1 || true
curl -s -X DELETE -u "$AUTH" "${BASE_URL}/addressbooks/admin/inttest/etag-rt.vcf" >/dev/null 2>&1 || true

echo "# --- Contacts: GET ---"

# ==========================================================================
# GET contact returns body
# ==========================================================================
test_name="GET contact returns body with correct content"
result=$(dav_full GET /addressbooks/admin/inttest/alice.vcf)
actual_status=$(echo "$result" | head -1)
actual_body=$(echo "$result" | tail -n +2)
assert_contains "$test_name" "200" "$actual_status" "$actual_body" "VCARD" "Alice Updated"

# ==========================================================================
# GET missing contact returns 404
# ==========================================================================
test_name="GET missing contact returns 404"
actual_status=$(dav GET /addressbooks/admin/inttest/nonexistent.vcf)
assert_response "$test_name" "404" "" "$actual_status" ""

# ==========================================================================
# GET addressbook collection returns concatenated contacts
# ==========================================================================
test_name="GET addressbook collection returns concatenated contacts"
result=$(dav_full GET /addressbooks/admin/inttest/)
actual_status=$(echo "$result" | head -1)
actual_body=$(echo "$result" | tail -n +2)
assert_contains "$test_name" "200" "$actual_status" "$actual_body" "VCARD"

echo "# --- Contacts: HEAD ---"

# ==========================================================================
# HEAD on contact returns 200
# ==========================================================================
test_name="HEAD on contact returns 200"
head_headers=$(dav_headers HEAD /addressbooks/admin/inttest/alice.vcf)
head_status=$(echo "$head_headers" | head -1 | grep -o '[0-9][0-9][0-9]')
if [ "$head_status" = "200" ]; then
  PASS=$((PASS + 1))
  echo "ok - ${test_name}"
else
  FAIL=$((FAIL + 1))
  ERRORS="${ERRORS}\nFAIL ${test_name}: expected 200, got ${head_status}"
  echo "not ok - ${test_name}"
fi

# ==========================================================================
# HEAD on contact includes ETag header
# ==========================================================================
test_name="HEAD on contact includes ETag header"
if echo "$head_headers" | grep -qi '^etag:'; then
  PASS=$((PASS + 1))
  echo "ok - ${test_name}"
else
  FAIL=$((FAIL + 1))
  ERRORS="${ERRORS}\nFAIL ${test_name}: missing ETag header"
  echo "not ok - ${test_name}"
fi

# ==========================================================================
# HEAD on missing contact returns 404
# ==========================================================================
test_name="HEAD on missing contact returns 404"
head_headers=$(dav_headers HEAD /addressbooks/admin/inttest/nope.vcf)
head_status=$(echo "$head_headers" | head -1 | grep -o '[0-9][0-9][0-9]')
if [ "$head_status" = "404" ]; then
  PASS=$((PASS + 1))
  echo "ok - ${test_name}"
else
  FAIL=$((FAIL + 1))
  ERRORS="${ERRORS}\nFAIL ${test_name}: expected 404, got ${head_status}"
  echo "not ok - ${test_name}"
fi

echo "# --- Contacts: REPORT ---"

# ==========================================================================
# REPORT addressbook returns contact
# ==========================================================================
test_name="REPORT addressbook returns contact with cr:address-data"
result=$(dav_full REPORT /addressbooks/admin/inttest/ -H "Content-Type: text/xml" \
  -d '<?xml version="1.0" encoding="UTF-8"?><cr:addressbook-query xmlns:d="DAV:" xmlns:cr="urn:ietf:params:xml:ns:carddav"><d:prop><d:getetag/><cr:address-data/></d:prop></cr:addressbook-query>')
actual_status=$(echo "$result" | head -1)
actual_body=$(echo "$result" | tail -n +2)
assert_contains "$test_name" "207" "$actual_status" "$actual_body" "Alice Updated" "cr:address-data" "getetag"

# ==========================================================================
# REPORT with prop-filter text-match filters contacts
# ==========================================================================
test_name="REPORT addressbook with prop-filter text-match filters contacts"
# Add a second contact
vcard_bob="BEGIN:VCARD
VERSION:3.0
UID:int-contact-bob
FN:Bob Builder
END:VCARD"
curl -s -o /dev/null -X PUT -u "$AUTH" \
  -H "Content-Type: text/vcard" \
  --data-binary "$vcard_bob" \
  "${BASE_URL}/addressbooks/admin/inttest/bob.vcf" 2>/dev/null

report_text='<?xml version="1.0" encoding="UTF-8"?><cr:addressbook-query xmlns:d="DAV:" xmlns:cr="urn:ietf:params:xml:ns:carddav"><d:prop><d:getetag/><cr:address-data/></d:prop><cr:filter><cr:prop-filter name="FN"><cr:text-match>Bob</cr:text-match></cr:prop-filter></cr:filter></cr:addressbook-query>'
result=$(dav_full REPORT /addressbooks/admin/inttest/ -H "Content-Type: text/xml" -d "$report_text")
actual_status=$(echo "$result" | head -1)
actual_body=$(echo "$result" | tail -n +2)
norm_actual=$(echo "$actual_body" | normalize)
if [ "$actual_status" = "207" ] && echo "$norm_actual" | grep -q 'Bob Builder' && ! echo "$norm_actual" | grep -q 'Alice'; then
  PASS=$((PASS + 1))
  echo "ok - ${test_name}"
else
  FAIL=$((FAIL + 1))
  ERRORS="${ERRORS}\nFAIL ${test_name}: should contain 'Bob Builder' but not 'Alice'"
  echo "not ok - ${test_name}"
fi

# ==========================================================================
# REPORT without auth returns 401
# ==========================================================================
test_name="REPORT addressbook without auth returns 401"
actual_status=$(dav_no_auth REPORT /addressbooks/admin/inttest/ -H "Content-Type: text/xml" -d '<x/>')
assert_response "$test_name" "401" "" "$actual_status" ""

echo "# --- Contacts: PROPPATCH ---"

# ==========================================================================
# PROPPATCH updates addressbook displayname
# ==========================================================================
test_name="PROPPATCH updates addressbook displayname and returns 207"
pp_addr='<d:propertyupdate xmlns:d="DAV:"><d:set><d:prop><d:displayname>Renamed Addr</d:displayname></d:prop></d:set></d:propertyupdate>'
result=$(dav_full PROPPATCH /addressbooks/admin/inttest/ -H "Content-Type: text/xml" -d "$pp_addr")
actual_status=$(echo "$result" | head -1)
actual_body=$(echo "$result" | tail -n +2)

expected_body=$(cat <<'XML'
<?xml version="1.0" encoding="UTF-8"?>
<d:multistatus xmlns:d="DAV:" xmlns:c="urn:ietf:params:xml:ns:caldav" xmlns:cr="urn:ietf:params:xml:ns:carddav" xmlns:cs="http://calendarserver.org/ns/" xmlns:x="http://apple.com/ns/ical/">
  <d:response>
    <d:href>/addressbooks/admin/inttest/</d:href>
    <d:propstat>
      <d:prop/>
      <d:status>HTTP/1.1 200 OK</d:status>
    </d:propstat>
  </d:response>
</d:multistatus>
XML
)
assert_response "$test_name" "207" "$expected_body" "$actual_status" "$actual_body"

# ==========================================================================
# PROPFIND confirms the rename
# ==========================================================================
test_name="PROPFIND addressbook after rename shows new displayname"
result=$(dav_full PROPFIND /addressbooks/admin/inttest/ -H "Depth: 0" -H "Content-Type: text/xml")
actual_status=$(echo "$result" | head -1)
actual_body=$(echo "$result" | tail -n +2)
assert_contains "$test_name" "207" "$actual_status" "$actual_body" "<d:displayname>Renamed Addr</d:displayname>"

# ==========================================================================
# PROPPATCH remove addressbook displayname
# ==========================================================================
test_name="PROPPATCH remove addressbook displayname returns 207"
remove_addr='<d:propertyupdate xmlns:d="DAV:"><d:remove><d:prop><d:displayname/></d:prop></d:remove></d:propertyupdate>'
actual_status=$(dav PROPPATCH /addressbooks/admin/inttest/ -H "Content-Type: text/xml" -d "$remove_addr")
assert_response "$test_name" "207" "" "$actual_status" ""

# ==========================================================================
# PROPFIND confirms displayname is removed
# ==========================================================================
test_name="PROPFIND addressbook after remove displayname shows no displayname"
result=$(dav_full PROPFIND /addressbooks/admin/inttest/ -H "Depth: 0" -H "Content-Type: text/xml")
actual_status=$(echo "$result" | head -1)
actual_body=$(echo "$result" | tail -n +2)
norm_actual=$(echo "$actual_body" | normalize)
if [ "$actual_status" = "207" ] && ! echo "$norm_actual" | grep -q '<d:displayname>'; then
  PASS=$((PASS + 1))
  echo "ok - ${test_name}"
else
  FAIL=$((FAIL + 1))
  ERRORS="${ERRORS}\nFAIL ${test_name}: displayname should be absent after remove"
  echo "not ok - ${test_name}"
fi

# Restore displayname
curl -s -o /dev/null -X PROPPATCH -u "$AUTH" -H "Content-Type: text/xml" \
  -d '<d:propertyupdate xmlns:d="DAV:"><d:set><d:prop><d:displayname>IntTest Addr</d:displayname></d:prop></d:set></d:propertyupdate>' \
  "${BASE_URL}/addressbooks/admin/inttest/" 2>/dev/null

