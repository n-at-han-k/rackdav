#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
COMPOSE_DIR="$ROOT_DIR/example"

# --- Unit tests ---
echo "=== Unit tests ==="
bundle exec scampi
echo ""

# --- Integration tests ---
echo "=== Integration tests (docker) ==="

cleanup() {
  echo ""
  echo "Shutting down docker compose..."
  docker compose -f "$COMPOSE_DIR/docker-compose.yml" down --timeout 5 2>/dev/null || true
}
trap cleanup EXIT

docker compose -f "$COMPOSE_DIR/docker-compose.yml" up -d --build 2>&1

# Wait for server to be ready (OPTIONS / doesn't require auth)
echo "Waiting for server..."
for i in $(seq 1 30); do
  if curl -sf -o /dev/null -X OPTIONS http://localhost:9292/ 2>/dev/null; then
    echo "Server ready."
    break
  fi
  if [ "$i" -eq 30 ]; then
    echo "Server failed to start within 30s"
    docker compose -f "$COMPOSE_DIR/docker-compose.yml" logs
    exit 1
  fi
  sleep 1
done

"$SCRIPT_DIR/integration"
